# Fire Calculator - Environment Variables
# Copy this file to .env and fill in your API keys

# Twelve Data API Key (Recommended - 800 calls/day free)
# Get yours at: https://twelvedata.com
TWELVE_DATA_API_KEY=your_twelvedata_api_key_here

# Alpha Vantage API Key (Alternative - 25 calls/day free)
# Get yours at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alphavantage_api_key_here

# Note: You only need ONE of the above API keys, not both
# The default data source is Twelve Data
